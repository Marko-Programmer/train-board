<Window x:Class="trainBoard.TrainDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Journey Details" Height="600" Width="450" 
        WindowStartupLocation="CenterOwner" Background="#F0F2F5"
        AllowsTransparency="False" WindowStyle="ThreeDBorderWindow">

    <Window.Resources>
        <Style x:Key="DetailCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="1" Opacity="0.1"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#DFE6E9"/>
            <Setter Property="Foreground" Value="#2D3436"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Width" Value="100"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#B2BEC3"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border x:Name="HeaderBorder" Grid.Row="0" Background="#007ACC" CornerRadius="12" Padding="20,15" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="🚆" FontSize="28" VerticalAlignment="Center" Margin="0,0,15,0"/>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock x:Name="txtHeader" FontSize="18" FontWeight="Bold" Foreground="White" Text="Train 12345"/>
                    <TextBlock Text="Full Route Schedule" FontSize="12" Foreground="#B3FFFFFF"/>
                </StackPanel>

                <Border Grid.Column="2" Background="White" CornerRadius="6" Padding="10,4" VerticalAlignment="Center">
                    <TextBlock x:Name="txtCarrier" Foreground="#007ACC" FontWeight="ExtraBold" FontSize="12"/>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource DetailCard}">
            <DataGrid x:Name="DetailsGrid" AutoGenerateColumns="False" IsReadOnly="True" 
                      Background="Transparent" BorderThickness="0" GridLinesVisibility="None"
                      RowHeight="50" FontSize="14" HeadersVisibility="Column" SelectionUnit="FullRow">

                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="#636E72"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Padding" Value="10,5"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="#F1F2F6"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                    </Style>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F8F9FA"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.Resources>

                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="STATION" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding StationName}" VerticalAlignment="Center" 
                                           Margin="15,0" FontWeight="SemiBold" Foreground="#2D3436"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="ARR." Width="70">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Arrival}" VerticalAlignment="Center" 
                                           HorizontalAlignment="Center" Foreground="#636E72"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="DEP." Width="70">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Departure}" VerticalAlignment="Center" 
                                           HorizontalAlignment="Center" FontWeight="Bold" Foreground="#007ACC"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="WAIT" Width="70">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="#F1F2F6" CornerRadius="4" Padding="4,2" 
                                        HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding StopDuration}" FontSize="10" Foreground="#2D3436"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Button Grid.Row="2" Content="Close Details" Style="{StaticResource SecondaryButton}" 
                Click="Close_Click" HorizontalAlignment="Right" Margin="0,15,0,0"/>
    </Grid>
</Window>
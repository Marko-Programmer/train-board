<Window x:Class="trainBoard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TrainBoard - Journey Planner" Height="650" Width="1050"
        WindowStartupLocation="CenterScreen" Background="#F0F2F5"
        KeyDown="Window_KeyDown">
    <Window.Resources>
        <Style x:Key="ModernCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="2" Opacity="0.1"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#005A9E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DetailsButton" TargetType="Button">
            <Setter Property="Background" Value="#E3F2FD"/>
            <Setter Property="Foreground" Value="#007ACC"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Width" Value="110"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#BBDEFB"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="45"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5,0,0,20">
            <TextBlock Text="🚆" FontSize="32" VerticalAlignment="Center" Margin="0,0,15,0"/>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="TrainBoard" FontSize="28" FontWeight="ExtraBold" Foreground="#1A1A1A"/>
                <TextBlock Text="Live Polish Railway Connections" FontSize="14" Foreground="#636E72"/>
            </StackPanel>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource ModernCard}" Margin="0,0,0,25">
            <Grid VerticalAlignment="Bottom">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="FROM" FontSize="11" FontWeight="Bold" Foreground="#B2BEC3" Margin="5,0,0,8"/>
                    <ComboBox x:Name="FromComboBox" IsEditable="True" IsTextSearchEnabled="False" 
                              StaysOpenOnEdit="True" DisplayMemberPath="Name" PreviewKeyUp="ComboBox_PreviewKeyUp"/>
                </StackPanel>

                <Button x:Name="BtnReverse" 
        Grid.Column="1" Content="⇄" FontSize="26" Foreground="#007ACC" 
        Background="Transparent" BorderThickness="0" Cursor="Hand"
        VerticalAlignment="Center" Margin="15,20,15,0" Click="BtnReverse_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <ContentPresenter />
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="TO" FontSize="11" FontWeight="Bold" Foreground="#B2BEC3" Margin="5,0,0,8"/>
                    <ComboBox x:Name="ToComboBox" IsEditable="True" IsTextSearchEnabled="False" 
                              StaysOpenOnEdit="True" DisplayMemberPath="Name" PreviewKeyUp="ComboBox_PreviewKeyUp"/>
                </StackPanel>

                <Button Grid.Column="3" Content="Find Connections" Width="190"
                        Style="{StaticResource PrimaryButton}" 
                        Margin="20,19,0,0" Click="ShowTrains_Click" VerticalAlignment="Bottom"/>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource ModernCard}">
            <DataGrid x:Name="TrainsDataGrid" AutoGenerateColumns="False" IsReadOnly="True" 
          Background="Transparent" BorderThickness="0" GridLinesVisibility="None"
          RowHeight="60" FontSize="14" HeadersVisibility="Column"
          HorizontalContentAlignment="Stretch" VerticalContentAlignment="Center">

                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="#636E72"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Padding" Value="0,0,0,12"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="#F1F2F6"/>
                    </Style>
                </DataGrid.Resources>

                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="TRAIN" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Number}" FontWeight="Bold" 
                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="DEPARTURE" Width="180">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding DepartureDisplay}" FontSize="16" FontWeight="ExtraBold" 
                                   Foreground="#2D3436" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding From}" FontSize="11" Foreground="#95A5A6" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="ARRIVAL" Width="180">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding ArrivalDisplay}" FontSize="16" FontWeight="ExtraBold" 
                                   Foreground="#2D3436" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding To}" FontSize="11" Foreground="#95A5A6" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="DURATION" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="#F1F2F6" CornerRadius="6" Padding="8,4" 
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding DurationDisplay}" FontSize="12" Foreground="#636E72"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="CARRIER" Width="140">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="#E67E22" CornerRadius="4" Padding="12,4" 
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Type}" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="ACTION" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Details" Style="{StaticResource DetailsButton}" 
                            Click="ViewDetails_Click" 
                            HorizontalAlignment="Center" 
                            VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Window>